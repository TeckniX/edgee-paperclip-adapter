{
  "name": "@tecknix/edgee-paperclip-adapter",
  "version": "0.1.0",
  "description": "Edgee compressed adapter for Paperclip AI - routes LLM traffic through Edgee for token compression",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc && node scripts/copy-packagejson.js",
    "copy:packagejson": "node -e \"const p=require('./package.json'),fs=require('fs');delete p.scripts;delete p.devDependencies;delete p.publishConfig;p.main='./index.js';p.types='./index.d.ts';p.exports={'.'. './index.js','./server':'./server/index.js'};fs.writeFileSync('./dist/package.json',JSON.stringify(p,null,2))\"",
    "dev": "tsc --watch",
    "publish": "npm run build && npm publish",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.416.0",
    "edgee": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
