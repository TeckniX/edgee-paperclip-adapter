{
  "name": "@tecknix/edgee-paperclip-adapter",
  "version": "0.2.0",
  "description": "Edgee compressed adapter for Paperclip AI - routes LLM traffic through Edgee for token compression",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./ui": "./src/ui/index.ts",
    "./cli": "./src/cli/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.416.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
