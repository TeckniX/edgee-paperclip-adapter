{
  "name": "@tecknix/edgee-paperclip-adapter",
  "version": "0.2.0",
  "description": "Edgee compressed adapter for Paperclip AI - routes LLM traffic through Edgee for token compression",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skills"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.416.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TeckniX/edgee-paperclip-adapter.git"
  },
  "keywords": [
    "paperclip",
    "ai-agent",
    "edgee",
    "adapter",
    "orchestration"
  ],
  "author": "TeckniX",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TeckniX/edgee-paperclip-adapter/issues"
  },
  "homepage": "https://github.com/TeckniX/edgee-paperclip-adapter#readme"
}
